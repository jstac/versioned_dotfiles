# This file needs to live in $HOME.  It's only job is to 
# point zsh to the location of config and other files (history, 
# plugins, etc.)
#
# 

# Set XDG
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"

# Zsh home
export ZDOTDIR=$HOME/.config/zsh
export ZHOMEDIR=$HOME/.config/zsh
export ZDATADIR=$XDG_DATA_HOME/zsh
export ZCACHEDIR=$XDG_CACHE_HOME/zsh



. "$HOME/.cargo/env"

# TeXlive — pick up the most recent installed year automatically. Lives in
# zshenv (not zshrc) so non-interactive nvim sessions etc. find latexmk.
_texlive_bin=$(ls -d /usr/local/texlive/[0-9]*/bin/x86_64-linux 2>/dev/null | sort -V | tail -1)
[ -n "$_texlive_bin" ] && export PATH=$_texlive_bin:$PATH
unset _texlive_bin
